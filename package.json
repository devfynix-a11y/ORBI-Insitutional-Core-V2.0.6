{
  "name": "orbi-sovereign-backend",
  "version": "25.5.1",
  "private": true,
  "type": "module",
  "description": "Headless Sovereign API Node - Universal Transaction Switch",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "render-build": "npm install && npm run build",
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "lint": "tsc --noEmit",
    "test": "tsx --test --test-force-exit tests/**/*.test.ts",
    "test:db:financial": "tsx tests/helpers/validateDbIntegrationEnv.ts read && tsx --test --test-force-exit tests/financialCoreDbIntegration.test.ts",
    "test:db:financial:write": "tsx tests/helpers/validateDbIntegrationEnv.ts write && tsx --test --test-force-exit tests/financialCoreDbMutation.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@simplewebauthn/server": "^13.2.3",
    "@simplewebauthn/types": "^12.0.0",
    "@supabase/supabase-js": "^2.96.0",
    "@vercel/node": "^5.6.18",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.1.0",
    "libphonenumber-js": "^1.12.38",
    "multer": "^2.1.0",
    "rate-limit-redis": "^4.3.1",
    "sanitize-html": "^2.17.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.15",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.5.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.2.4",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "undici": "^6.24.1"
  }
}
