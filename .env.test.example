# Financial DB integration test env example
# Use only against an isolated, disposable Supabase project or schema.

ORBI_RUN_DB_INTEGRATION=true
ORBI_DB_INTEGRATION_ALLOW_WRITES=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional test tuning
ORBI_DB_TEST_AMOUNT=0.01
ORBI_DB_TEST_INSUFFICIENT_AMOUNT=999999

# Write-enabled fixture ids
ORBI_DB_TEST_USER_ID=00000000-0000-0000-0000-000000000001
ORBI_DB_TEST_SOURCE_WALLET_ID=00000000-0000-0000-0000-000000000002
ORBI_DB_TEST_TARGET_WALLET_ID=00000000-0000-0000-0000-000000000003
ORBI_DB_TEST_INTERNAL_TRANSFER_VAULT_ID=00000000-0000-0000-0000-000000000004
ORBI_DB_TEST_LOW_BALANCE_WALLET_ID=00000000-0000-0000-0000-000000000005
ORBI_DB_TEST_LOCKED_WALLET_ID=00000000-0000-0000-0000-000000000006
ORBI_DB_TEST_REVIEW_ACTOR_ID=00000000-0000-0000-0000-000000000007
ORBI_DB_TEST_DRIFT_WALLET_ID=00000000-0000-0000-0000-000000000008
ORBI_DB_TEST_WEBHOOK_PARTNER_ID=00000000-0000-0000-0000-000000000009
